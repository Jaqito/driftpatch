{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@driftpatch/core": ["./packages/core/src/index.ts"],
      "@driftpatch/core/types": ["./packages/core/src/types.ts"],
      "@driftpatch/adapter-sdk": ["./packages/adapter-sdk/src/index.ts"],
      "@driftpatch/adapter-sdk/test": ["./packages/adapter-sdk/src/test.ts"],
      "@driftpatch/adapter-generic": ["./packages/adapter-generic/src/index.ts"],
      "@driftpatch/eval": ["./packages/eval/src/index.ts"]
    }
  }
}
